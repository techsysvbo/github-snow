{
  "name": "snow-github-app-action",
  "version": "1.0.0",
  "description": "GitHub Action for ServiceNow pre-merge approval gate",
  "main": "dist/index.js",
  "scripts": {
    "build": "npx @vercel/ncc build index.js -o dist --source-map --license licenses.txt",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write '**/*.{js,json,md}'",
    "prepare": "npm run build",
    "dev": "node index.js"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@octokit/auth-app": "^7.1.2",
    "@octokit/rest": "^21.1.1"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.1",
    "eslint": "^9.17.0",
    "eslint-plugin-jest": "^28.9.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
