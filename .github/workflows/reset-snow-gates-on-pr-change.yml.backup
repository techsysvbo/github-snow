name: Reset SNOW Gates On PR Change

on:
  pull_request:
    branches:
      - main
    types:
      - opened
      - reopened
      - synchronize

permissions:
  contents: read
  statuses: write
  pull-requests: read

jobs:
  reset-snow-gates:
    name: reset-snow-gates
    runs-on: ubuntu-latest

    steps:
      - name: Reset SNOW-controlled commit statuses to pending
        uses: actions/github-script@v7
        with:
          script: |
            const pr = context.payload.pull_request;

            const statuses = [
              {
                context: "snow-approval",
                description: "Waiting for ServiceNow approval"
              },
              {
                context: "snow-deployment-gate",
                description: "Waiting for ServiceNow deployment gate approval"
              }
            ];

            for (const item of statuses) {
              await github.rest.repos.createCommitStatus({
                owner: context.repo.owner,
                repo: context.repo.repo,
                sha: pr.head.sha,
                state: "pending",
                context: item.context,
                description: item.description,
                target_url: pr.html_url
              });
            }
